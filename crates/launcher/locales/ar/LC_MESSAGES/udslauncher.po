#: rust_files.tmp:238 rust_files.tmp:893
msgid ""
"The server {}\n"
"must be approved.\n"
"Only approve UDS servers you trust.\n"
"Do you want to continue?"
msgstr ""
"الخادم {}\n"
"يجب الموافقة عليها.\n"
"قم بالموافقة على خوادم UDS التي تثق بها فقط.\n"
"هل تريد الاستمرار؟"

#: rust_files.tmp:245 rust_files.tmp:900
msgid "Host {} not approved by user."
msgstr "لم تتم الموافقة على المضيف {} من قبل المستخدم."

