msgid "Starting connection..."
msgstr "بدء الاتصال..."

#: rust_files.tmp:296 rust_files.tmp:951
msgid ""
"Client version {} is outdated. Required version is {}.\n"
"Please download the latest version from\n"
"{}\n"
"and try again."
