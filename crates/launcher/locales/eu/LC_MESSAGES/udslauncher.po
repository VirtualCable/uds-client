#: rust_files.tmp:238 rust_files.tmp:893
msgid ""
"The server {}\n"
"must be approved.\n"
"Only approve UDS servers you trust.\n"
"Do you want to continue?"
msgstr ""
"Zerbitzaria {}\n"
"onartu behar da.\n"
"Onartu fidagarriak diren UDS zerbitzariak bakarrik.\n"
"Jarraitu nahi duzu?"

#: rust_files.tmp:245 rust_files.tmp:900
msgid "Host {} not approved by user."
msgstr "Erabiltzaileak ez du {} ostalaria onartu."

#: rust_files.tmp:272 rust_files.tmp:927
msgid "Starting connection..."
msgstr "Konexioa hasten..."

#: rust_files.tmp:296 rust_files.tmp:951
msgid ""
"Client version {} is outdated. Required version is {}.\n"
"Please download the latest version from\n"
"{}\n"
"and try again."
msgstr ""
"Bezeroaren {} bertsioa zaharkituta dago. Beharrezko bertsioa {} da.\n"
"Mesedez, deskargatu azken bertsioa hemendik:\n"
"{}\n"
"eta saiatu berriro."

#: rust_files.tmp:311 rust_files.tmp:966
msgid ""
"A newer client version {} is available. Current version is {}.\n"
"{}|Download the latest version"
msgstr ""
"{} bezero bertsio berriago bat eskuragarri dago. Uneko bertsioa {} da.\n"
"{}|Deskargatu azken bertsioa"

#: rust_files.tmp:325 rust_files.tmp:980
msgid "Script signature verification failed."
msgstr "Script-aren sinaduraren egiaztapenak huts egin du."

#: rust_files.tmp:336 rust_files.tmp:991
msgid ""
"Access denied by broker.\n"
"{}"
msgstr ""
"Brokerrak sarbidea ukatu du.\n"
"{}"

#: rust_files.tmp:341 rust_files.tmp:996
msgid "Preparing connection..."
msgstr "Konexioa prestatzen..."

